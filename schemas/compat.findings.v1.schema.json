{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openfeapp/web-compat/main/schemas/compat.findings.v1.schema.json",
  "title": "compat-findings/v1",
  "type": "object",
  "required": ["format", "generated_at", "tool", "findings"],
  "properties": {
    "$schema": { "type": "string" },
    "format": { "const": "compat-findings/v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "tool": {
      "type": "object",
      "required": ["scanner"],
      "properties": {
        "scanner": { "type": "string", "minLength": 1 },
        "registry": { "type": "string" }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "ref", "key", "selector", "evidence"],
        "properties": {
          "kind": { "const": "bcd" },
          "ref": { "type": "string", "pattern": "^bcd:" },
          "key": { "type": "string", "minLength": 1 },
          "selector": {
            "type": "object",
            "required": ["prefix", "alternative_name", "allow_flags", "allow_partial_implementation"],
            "properties": {
              "prefix": { "type": ["string", "null"] },
              "alternative_name": { "type": ["string", "null"] },
              "allow_flags": { "type": "boolean" },
              "allow_partial_implementation": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["path", "rule"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "loc": { "type": "string" },
                "rule": { "type": "string", "minLength": 1 },
                "snippet": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
